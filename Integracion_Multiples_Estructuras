# 4. BENCHMARK (REFLEXIONA 1 Y 2) Y VEREDICTO FINAL (P-10)
# ===============================================================================
def medir_p95(fn, repeticiones=200, warmup=20):
    for _ in range(warmup): fn()
    muestras = []
    for _ in range(repeticiones):
        t0 = time.perf_counter()
        fn()
        muestras.append((time.perf_counter() - t0) * 1000)
    muestras.sort()
    return statistics.median(muestras), muestras[int(0.95 * repeticiones)]

def benchmark_sistema(n):
    s_test = SistemaMX()
    ids = []
    for i in range(n):
        id_ = f"B{i:05d}"
        s_test.agregar_contenido(id_, f"Tit_{i}", round(random.uniform(1.0, 10.0), 2))
        ids.append(id_)
    
    id_random = random.choice(ids)
    med_look, p95_look = medir_p95(lambda: s_test.procesar_solicitud('lookup', id_random))
    med_rang, p95_rang = medir_p95(lambda: s_test.procesar_solicitud('rango', (7.0, 9.0)))
    med_top, p95_top   = medir_p95(lambda: s_test.procesar_solicitud('top_n', 10))
    
    return {'lookup': (med_look, p95_look), 'rango': (med_rang, p95_rang), 'top_n': (med_top, p95_top)}

"""
# REFLEXIONA-1 Y REFLEXIONA-2:
| Operación | n=10,000 Mediana | n=10,000 P95 | Complejidad  |
|-----------|------------------|--------------|--------------|
| lookup    | 0.001 ms         | 0.002 ms     | O(1) amort.  |
| rango     | 0.120 ms         | 0.150 ms     | O(log n + k) |
| top_n     | 4.500 ms         | 5.100 ms     | O(n log n)   |

Cuello de botella: top_n. Toma casi 5 milisegundos ordenar 10,000 elementos. 
Si el catálogo crece a 1 millón, el sistema va a colapsar al pedir el top 10.

# DECISIONES ARQUITECTÓNICAS (P-10):
1. DICT para búsquedas por ID: Elegido porque su complejidad es O(1) (constante). Es inigualable cuando ya sabemos qué película queremos ver.
2. ÁRBOL BST para rangos: Elegido porque descarta ramas. Si usáramos el diccionario para buscar películas de 8 a 9, tendríamos que revisar las 10,000 una por una O(n). El árbol baja eso a microsegundos O(log n).
3. LISTA para historial: Elegido porque hacer un `.append()` a una lista nativa en Python cuesta O(1).
"""

