# ===============================================================================
# 1. ESTRUCTURAS BÁSICAS
# ===============================================================================
class NodoBST:
    def __init__(self, clave, valor):
        self.clave = clave  # Puntaje de la película
        # MUY IMPORTANTE: Guardamos el valor como una lista [valor]. 
        # Si dos películas tienen el mismo puntaje, las metemos juntas aquí en vez de borrarlas.
        self.valor = [valor] if not isinstance(valor, list) else valor
        self.izq = None
        self.der = None

# ===============================================================================
# 2. SISTEMA CENTRAL (A-3, A-4, A-5)
# ===============================================================================
class SistemaMX:
    def __init__(self):
        # APLICA-3: Inicializamos nuestras 3 estructuras vacías.
        self.catalogo = {}         # Diccionario para búsquedas rápidas por ID
        self.bst_raiz = None       # Raíz de nuestro árbol para rangos de puntaje
        self.historial = []        # Lista (Pila) para saber qué fue lo último insertado

    # APLICA-4: Inserción Consistente
    def agregar_contenido(self, id_contenido, titulo, puntaje, pais="México"):
        """ Agrega una película a las 3 estructuras al mismo tiempo para no generar errores. """
        # 1. Validar que no nos metan basura
        if id_contenido in self.catalogo:
            raise ValueError(f"El ID '{id_contenido}' ya existe.")
        if not (0.0 <= puntaje <= 10.0):
            raise ValueError("El puntaje debe estar entre 0.0 y 10.0")

        contenido = {'id': id_contenido, 'titulo': titulo, 'puntaje': puntaje, 'pais': pais}

        # 2. Guardar en Diccionario (Súper rápido: O(1))
        self.catalogo[id_contenido] = contenido

        # 3. Guardar en el Árbol (Rápido: O(log n))
        self.bst_raiz = self._bst_insertar(self.bst_raiz, puntaje, contenido)

        # 4. Guardar en el Historial
        self.historial.append(id_contenido)
        return True

    def _bst_insertar(self, nodo, clave, valor):
        """ Lógica recursiva del árbol. Avanza a izquierda o derecha según el puntaje. """
        if nodo is None:
            return NodoBST(clave, valor)
        
        if clave < nodo.clave:
            nodo.izq = self._bst_insertar(nodo.izq, clave, valor)
        elif clave > nodo.clave:
            nodo.der = self._bst_insertar(nodo.der, clave, valor)
        else:
            # Si el puntaje ya existe (Empate), solo lo agregamos a la lista de esa "cajita".
            nodo.valor.append(valor)
        return nodo

    # APLICA-5: Enrutador de Operaciones (El "Recepcionista")
    def procesar_solicitud(self, tipo, param=None):
        """ Según lo que pida el usuario, decidimos qué estructura usar. """
        if tipo == 'lookup':
            # Si piden ID exacto, usamos el Diccionario porque es instantáneo.
            return self.catalogo.get(param, None)
            
        elif tipo == 'rango':
            # Si piden un rango (ej. 8 a 9), usamos el Árbol.
            minv, maxv = param
            resultado = []
            self._bst_rango(self.bst_raiz, minv, maxv, resultado)
            return resultado
            
        elif tipo == 'top_n':
            # Si piden las N mejores, ordenamos los valores del diccionario.
            n = param or 5
            todos = sorted(self.catalogo.values(), key=lambda x: x['puntaje'], reverse=True)
            return todos[:n]
            
        elif tipo == 'historial':
            # Si piden lo último agregado, tomamos los últimos K elementos de la lista.
            k = param or 5
            return self.historial[-k:]
            
        else:
            raise ValueError("No entiendo ese tipo de solicitud.")

    def _bst_rango(self, nodo, minv, maxv, resultado):
        """ 
        Busca en el árbol ignorando ramas que no sirven (Poda Lógica). 
        """
        if nodo is None:
            return
        
        # PODA: Si el nodo actual es MAYOR al mínimo que busco, vale la pena revisar a la izquierda.
        if nodo.clave > minv:
            self._bst_rango(nodo.izq, minv, maxv, resultado)
            
        # Si el nodo actual está dentro de mi rango, guardo todas las películas de esa lista.
        if minv <= nodo.clave <= maxv:
            resultado.extend(nodo.valor)
            
        # PODA: Si el nodo actual es MENOR al máximo que busco, vale la pena revisar a la derecha.
        if nodo.clave < maxv:
            self._bst_rango(nodo.der, minv, maxv, resultado)

# ===============================================================================
# 3. PRUEBAS DE INTEGRIDAD Y CASOS EXTREMOS (V-8 Y V-9)
# ===============================================================================
def contar_nodos_bst(nodo):
    """ Cuenta cuántas películas hay realmente en el árbol. """
    if nodo is None: return 0
    # Sumamos el tamaño de la lista de valores, más lo de la izq, más lo de la der.
    return len(nodo.valor) + contar_nodos_bst(nodo.izq) + contar_nodos_bst(nodo.der)

def verificar_invariante_cruzada(sistema):
    """ V-9: Verifica que ninguna estructura se haya quedado atrás (desincronizada). """
    errores = []
    n_dict = len(sistema.catalogo)
    n_bst  = contar_nodos_bst(sistema.bst_raiz)
    n_hist = len(sistema.historial)

    if n_dict != n_bst: errores.append(f"❌ Error: Dict tiene {n_dict} pero BST tiene {n_bst}.")
    if n_hist != n_dict: errores.append(f"❌ Error: Historial tiene {n_hist} pero Dict tiene {n_dict}.")

    if not errores: print(f"✅ Invariante cruzada perfecta: {n_dict} películas sincronizadas en todos lados.")
    return errores

