    assert len(r) >= 2
    print("✅ V-4: Soporta empates exactos (mismo puntaje) gracias a que usamos listas en los Nodos.")

def caso_v5_equipo_historial_exagerado(s):
    """ ¿Qué pasa si piden las últimas 1000 películas pero solo hay 20? """
    r = s.procesar_solicitud('historial', 1000)
    assert len(r) == len(s.historial)
    print("✅ V-5: Si piden más historial del que existe, Python lo recorta solo sin fallar.")

